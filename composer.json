{
    "name": "waaseyaa/search",
    "description": "Search provider interface and DTOs for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.4",
        "twig/twig": "^3.0",
        "waaseyaa/foundation": "@dev",
        "waaseyaa/database-legacy": "@dev",
        "waaseyaa/entity": "@dev",
        "symfony/event-dispatcher": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Search\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Search\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        },
        "waaseyaa": {
            "providers": [
                "Waaseyaa\\Search\\SearchServiceProvider"
            ]
        }
    }
}
