{
    "name": "waaseyaa/search",
    "description": "Search provider interface and DTOs for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.5",
        "twig/twig": "^3.0",
        "waaseyaa/foundation": "^0.1.0-alpha.263",
        "waaseyaa/database-legacy": "^0.1.0-alpha.263",
        "waaseyaa/entity": "^0.1.0-alpha.263",
        "waaseyaa/entity-storage": "^0.1.0-alpha.263",
        "waaseyaa/access": "^0.1.0-alpha.263",
        "symfony/event-dispatcher": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Search\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Search\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        },
        "waaseyaa": {
            "providers": [
                "Waaseyaa\\Search\\SearchServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "repositories": [
        {
            "type": "path",
            "url": "../foundation"
        },
        {
            "type": "path",
            "url": "../database-legacy"
        },
        {
            "type": "path",
            "url": "../entity"
        },
        {
            "type": "path",
            "url": "../entity-storage"
        },
        {
            "type": "path",
            "url": "../access"
        }
    ]
}
